// ARK Server Manager — data model (PLANNING.md → Data model).
// SQLite has no native enums, so enum-typed columns are stored as TEXT using the
// string values from @ark/shared (Game, ServerState, EventType, ...).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("admin")
  /// Bumped to invalidate every outstanding JWT for this user (logout-all).
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Manager-level key/value config. Secret values are AES-256-GCM encrypted at rest.
model ManagerSetting {
  key       String   @id
  value     String
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Cluster {
  id          String   @id @default(cuid())
  name        String
  clusterId   String   @unique // the ARK cluster id passed to member servers
  transferDir String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  servers     Server[]
}

model Server {
  id        String  @id @default(cuid())
  name      String
  game      String // Game enum value (ASA | ASE)
  map       String
  state     String  @default("Stopped") // ServerState enum value
  maxPlayers Int    @default(70)

  clusterId String?
  cluster   Cluster? @relation(fields: [clusterId], references: [id])

  // Allocated ports (deterministic block, see PortAllocation)
  gamePort      Int
  rawSocketPort Int
  queryPort     Int
  rconPort      Int

  // Passwords — encrypted at rest, never serialized to the API
  adminPasswordEnc     String?
  serverPasswordEnc    String?
  spectatorPasswordEnc String?

  // Config + mods
  configJson String @default("{}") // ServerConfigValues JSON
  modIds     String @default("[]") // JSON array of CurseForge/Workshop ids
  // Per-server SteamGridDB art override (GameArtwork JSON). Null keys fall back
  // to the game-wide default resolved by ArtworkService.
  artworkJson String?

  // Runtime tracking
  containerId      String?
  installedBuildId String?
  // Advanced: pin the game image to a specific tag instead of the shipped default.
  // Null = use the default tag. Applied on the next start (pull + recreate).
  imageTag         String?
  // Last crash's container exit reason (exit code + a log tail), captured when a
  // running/starting container exits unexpectedly. Null once it starts cleanly.
  crashReason      String?
  updateAvailable  Boolean @default(false)
  // True when an installed mod (Valheim/Thunderstore or a pinned Minecraft modpack)
  // has a newer version — set by the mod-update poller (ModUpdatesService).
  modUpdateAvailable Boolean @default(false)
  // True when settings changed after the running container was created, so the
  // UI can offer a Restart (to apply them) instead of a disabled Start.
  configDirty      Boolean @default(false)
  ramLimitMb       Int?
  cpuLimit         Float?
  // User-defined extra environment variables injected into the game container.
  // JSON: Array<{ key: string; value: string }>
  extraEnvJson     String   @default("[]")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  modInstalls ModInstall[]
  schedules   Schedule[]
  snapshots   Snapshot[]
  sightings   PlayerSighting[]

  @@index([clusterId])
}

model Mod {
  id           String  @id @default(cuid())
  game         String
  source       String // "curseforge" | "workshop"
  remoteId     String // CurseForge project id / Workshop file id
  name         String
  thumbnailUrl String?
  extra        String? // per-game extras JSON (e.g. Zomboid's {"pzModIds":[...]})

  installs ModInstall[]

  @@unique([game, source, remoteId])
}

model ModInstall {
  id            String  @id @default(cuid())
  serverId      String
  server        Server  @relation(fields: [serverId], references: [id], onDelete: Cascade)
  modId         String
  mod           Mod     @relation(fields: [modId], references: [id])
  loadOrder     Int     @default(0)
  pinnedVersion String?
  enabled       Boolean @default(true)

  @@unique([serverId, modId])
}

model Schedule {
  id          String    @id @default(cuid())
  serverId    String
  server      Server    @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name        String
  cron        String
  action      String // restart | update | update-if-available | backup | stop | start
  warnMinutes Int       @default(10)
  enabled     Boolean   @default(true)
  // Skip disruptive actions (restart/update/stop) while players are online.
  skipIfPlayersOnline Boolean @default(false)
  lastRunAt   DateTime?
  // Set for ONE-TIME schedules: the absolute instant to fire once. When non-null,
  // `cron` is ignored for scheduling — a poll fires it (and catches up if the
  // manager was briefly down). Null = recurring (driven by `cron`).
  runAt       DateTime?
  createdAt   DateTime  @default(now())
}

model Snapshot {
  id        String   @id @default(cuid())
  serverId  String
  server    Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  path      String
  sizeBytes Int?
  reason    String // manual | pre-update | pre-restart | scheduled
  createdAt DateTime @default(now())
}

model SettingProfile {
  id         String   @id @default(cuid())
  name       String
  game       String
  configJson String
  createdAt  DateTime @default(now())
}

model PortAllocation {
  id        String   @id @default(cuid())
  serverId  String   @unique
  basePort  Int      @unique // block base; the 4 ports are derived from this
  createdAt DateTime @default(now())
}

model Job {
  id        String   @id @default(cuid())
  serverId  String?
  type      String // install | update | backup
  state     String // pending | running | success | failed
  progress  Int      @default(0)
  log       String   @default("")
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EventLog {
  id        String   @id @default(cuid())
  type      String
  serverId  String?
  clusterId String?
  message   String
  dataJson  String?
  createdAt DateTime @default(now())

  @@index([serverId])
  @@index([createdAt])
}

// A player seen on a server (via RCON player lists or join-log parsing). Powers
// the Players tab: whitelist/ban/admin actions per game.
model PlayerSighting {
  id          String   @id @default(cuid())
  serverId    String
  server      Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  name        String
  // Platform id when known: SteamID64, EOS id, Bedrock XUID… (needed for the
  // id-based access lists; some games only expose names).
  playerId    String?
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  // Playtime analytics, fed by the 60s player-list poll (games with a live
  // player list only — log-line-captured games can't measure presence).
  minutesPlayed  Int    @default(0)
  hourCountsJson String @default("[]") // 24 ints, UTC hour-of-day histogram

  @@unique([serverId, name])
}
